{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint \"resources/js/**/*.{js,vue}\"",
    "lint:fix": "eslint \"resources/js/**/*.{js,vue}\" --fix",
    "format": "prettier --write \"resources/js/**/*.{js,vue,css,scss}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "axios": "^1.11.0",
    "concurrently": "^9.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "laravel-vite-plugin": "^2.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^24.39.1",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.7",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "html2pdf.js": "^0.14.0",
    "vue": "^3.5.29",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  }
